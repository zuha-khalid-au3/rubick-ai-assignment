# Copy this file to .env and fill in your values
OPENAI_API_KEY=sk-...         # Optional: only needed for LLM fallback enrichment
DATABASE_URL=postgres://rubick:rubick_secret@localhost:5433/rubick_catalog
REDIS_URL=redis://localhost:6380
ML_SERVICE_URL=http://localhost:8000
NODE_ENV=development
PORT=3001
CRAWLER_ENABLED=true           # Background price crawler (set false to disable)
CRAWL_HTTP_ENABLED=true        # Fetch real prices via HTTP (Myntra works best)
CRAWL_HTTP_FALLBACK=true       # Fall back to simulated prices when HTTP fails
CRAWL_INTERVAL_MS=15000        # Crawl every 15 seconds
CRAWL_BATCH_SIZE=2             # Products updated per tick
CRAWL_REQUEST_DELAY_MS=2500    # Min delay between requests to same domain
CRAWL_HTTP_TIMEOUT_MS=25000    # HTTP fetch timeout
# SCRAPERAPI_KEY=...           # Optional: proxy for Amazon/Flipkart bot blocks
# CRAWL_PROXY_URL=http://user:pass@host:port
